<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory android:title="@string/configuration">

        <SwitchPreference
            android:defaultValue="false"
            android:key="useKana"
            android:summary="@string/use_kana_summary"
            android:title="@string/use_kana_title" />

        <EditTextPreference
            android:defaultValue="4200"
            android:hint="4200"
            android:inputType="number"
            android:key="recordStart"
            android:summary="@string/record_start_summary"
            android:title="@string/record_start_title" />

        <EditTextPreference
            android:defaultValue="9600"
            android:hint="9600"
            android:key="recordEnd"
            android:summary="@string/record_end_summary"
            android:title="@string/record_end_title" />

        <SwitchPreference
            android:defaultValue="false"
            android:key="customBGM"
            android:summary="@string/custom_bgm_summary"
            android:title="@string/custom_bgm_title" />

        <Preference
            android:defaultValue="None"
            android:key="customBGMFile"
            android:summary="None"
            android:title="@string/custom_bgm_file_title" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/appearance">

        <SwitchPreference
            android:key="darkMode"
            android:summary="@string/dark_mode_summary"
            android:title="@string/dark_mode_title" />

    </PreferenceCategory>

</PreferenceScreen>
